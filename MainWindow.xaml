<Window x:Class="CyberSecurityChatBotWithUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CyberSecurityChatBotWithUI"
        mc:Ignorable="d"
        Title="CyberSecurity Awareness ChatBot"
        Height="560" Width="820"
        Background="#0D0D0D">

    <Window.Resources>

        <!-- ── Colour palette ────────────────────────────────────────────── -->
        <!-- #00FF41  matrix green  – bot label                              -->
        <!-- #00BFFF  electric cyan – user label                             -->
        <!-- #FF4500  alert orange  – exit button / dividers                 -->
        <!-- #0D0D0D  near-black    – window / input backgrounds             -->
        <!-- #1A1A1A  dark surface  – chat background                        -->
        <!-- #C8C8C8  light grey    – body text                              -->

        <!-- Shared font for every text element -->
        <Style TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="Foreground"  Value="#C8C8C8"/>
        </Style>

        <!-- Chat RichTextBox -->
        <Style x:Key="ChatBoxStyle" TargetType="RichTextBox">
            <Setter Property="FontFamily"                Value="Consolas"/>
            <Setter Property="FontSize"                  Value="13"/>
            <Setter Property="Background"                Value="#1A1A1A"/>
            <Setter Property="Foreground"                Value="#C8C8C8"/>
            <Setter Property="BorderBrush"               Value="#00FF41"/>
            <Setter Property="BorderThickness"           Value="1"/>
            <Setter Property="Padding"                   Value="8"/>
            <Setter Property="IsReadOnly"                Value="True"/>
            <Setter Property="VerticalScrollBarVisibility" Value="Auto"/>
            <Setter Property="IsDocumentEnabled"         Value="True"/>
        </Style>

        <!-- Message input TextBox -->
        <Style x:Key="InputBoxStyle" TargetType="TextBox">
            <Setter Property="FontFamily"      Value="Consolas"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="Background"      Value="#1A1A1A"/>
            <Setter Property="Foreground"      Value="#C8C8C8"/>
            <Setter Property="CaretBrush"      Value="#00FF41"/>
            <Setter Property="BorderBrush"     Value="#00FF41"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"         Value="6,4"/>
        </Style>

        <!-- Send button -->
        <Style x:Key="SendButtonStyle" TargetType="Button">
            <Setter Property="FontFamily"   Value="Consolas"/>
            <Setter Property="FontSize"     Value="13"/>
            <Setter Property="FontWeight"   Value="Bold"/>
            <Setter Property="Background"   Value="#1A1A1A"/>
            <Setter Property="Foreground"   Value="#00FF41"/>
            <Setter Property="BorderBrush"  Value="#00FF41"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor"       Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#00FF41"/>
                    <Setter Property="Foreground" Value="#0D0D0D"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Exit button -->
        <Style x:Key="ExitButtonStyle" TargetType="Button">
            <Setter Property="FontFamily"   Value="Consolas"/>
            <Setter Property="FontSize"     Value="13"/>
            <Setter Property="FontWeight"   Value="Bold"/>
            <Setter Property="Background"   Value="#1A1A1A"/>
            <Setter Property="Foreground"   Value="#FF4500"/>
            <Setter Property="BorderBrush"  Value="#FF4500"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor"       Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#FF4500"/>
                    <Setter Property="Foreground" Value="#0D0D0D"/>
                </Trigger>
            </Style.Triggers>
        </Style>

    </Window.Resources>

    <Grid Background="#0D0D0D" Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>   <!-- header   -->
            <RowDefinition Height="*"/>      <!-- chat     -->
            <RowDefinition Height="Auto"/>   <!-- input    -->
            <RowDefinition Height="Auto"/>   <!-- buttons  -->
        </Grid.RowDefinitions>

        <!-- ── Header ─────────────────────────────────────────────────────── -->
        <StackPanel Grid.Row="0" Orientation="Horizontal"
                    HorizontalAlignment="Center" Margin="0,0,0,14">
            <Image Width="40" Height="40" Source="/cyber.png" Margin="0,0,10,0"/>
            <TextBlock Text="CyberSecurity Awareness ChatBot"
                       FontSize="22" FontWeight="Bold"
                       Foreground="#00FF41"
                       FontFamily="Consolas"
                       VerticalAlignment="Center"/>
        </StackPanel>

        <!-- ── Chat display ────────────────────────────────────────────────── -->
        <RichTextBox x:Name="txtChat"
                     Grid.Row="1"
                     Style="{StaticResource ChatBoxStyle}"
                     Margin="0,0,0,10"/>

        <!-- ── Message input ───────────────────────────────────────────────── -->
        <TextBox x:Name="txtMessage"
                 Grid.Row="2"
                 Style="{StaticResource InputBoxStyle}"
                 Height="36"
                 Margin="0,0,0,10"/>

        <!-- ── Buttons ─────────────────────────────────────────────────────── -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Center">
            <Button x:Name="btnSend"
                    Content="[ SEND ]"
                    Style="{StaticResource SendButtonStyle}"
                    Width="110" Height="34"
                    Margin="0,0,12,0"
                    Click="BtnSend_Click"/>

            <Button x:Name="btnExit"
                    Content="[ EXIT ]"
                    Style="{StaticResource ExitButtonStyle}"
                    Width="110" Height="34"
                    Click="BtnExit_Click"/>
        </StackPanel>

    </Grid>
</Window>
